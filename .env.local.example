# ── Supabase (same project as xm-crm / xm-dash) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://osnufkvvbsluxkukkqus.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Auth (simple password gate, same pattern as xm-dash) ──────────────────
DASHBOARD_PASSWORD=replace_with_strong_admin_password
SESSION_SECRET=replace_with_long_random_session_secret
# Controls minimum capability of dashboard session cookie when no explicit role cookie is present.
# Allowed: admin, ops, sales, seller, viewer
DASHBOARD_ROLE=admin

# ── Brevo (email automation engine) ───────────────────────────────────────
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
# Sender profile used when provisioning campaign templates during deploy.
BREVO_SENDER_NAME=XtraMiles Team
BREVO_SENDER_EMAIL=team@xtramiles.com
# Optional reply-to override.
BREVO_REPLY_TO_EMAIL=support@xtramiles.com
# Shared secret check for incoming Brevo webhooks.
# Configure in webhook URL as query param token or custom header.
BREVO_WEBHOOK_SECRET=replace_with_long_random_secret
# Optional HMAC verification (if your webhook sender is configured to sign requests).
BREVO_WEBHOOK_SIGNING_SECRET=optional_hmac_secret

# ── Metabase (production MySQL — read-only) ───────────────────────────────
METABASE_URL=https://metabase.xtramiles.in
METABASE_API_KEY=your_metabase_api_key_here
METABASE_DB_ID=2

# ── Gemini AI (campaign builder agent) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Campaign scheduler (Vercel cron) ──────────────────────────────────────
# Secures the hourly POST /api/campaigns/execute cron endpoint.
# Vercel sets Authorization: Bearer <CRON_SECRET> on cron requests automatically.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be set in Vercel → Project Settings → Environment Variables (all environments).
CRON_SECRET=replace_with_long_random_secret
# Maximum emails dispatched per scheduler run (respects Brevo daily quota).
# Default 290 = free tier 300/day minus 10 headroom.
# Raise after upgrading Brevo: Starter ~2000, Business ~10000+.
# Brevo free tier (300/day): MAX_SENDS_PER_DAY=290  ← current plan
# Brevo Starter 5k/month:   MAX_SENDS_PER_DAY=150
# Brevo Starter 20k/month:  MAX_SENDS_PER_DAY=600
# Brevo Business 100k+/mo:  MAX_SENDS_PER_DAY=3000
MAX_SENDS_PER_DAY=290

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://xm-email.vercel.app

# ── Brevo webhook setup (run once after deploy) ───────────────────────────
# Register via: POST /api/webhooks/brevo/register
# Or manually in Brevo dashboard → Transactional → Webhooks
# Webhook URL (recommended): https://xm-email.vercel.app/api/webhooks/brevo?token=<BREVO_WEBHOOK_SECRET>
# Events: delivered, opened, clicked, softBounce, hardBounce, unsubscribed, spam
